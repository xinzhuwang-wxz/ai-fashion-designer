{
  "1": {
    "inputs": {
      "ckpt_name": "v1-5-pruned-emaonly.safetensors"
    },
    "class_type": "CheckpointLoaderSimple",
    "_meta": {"title": "Load Checkpoint"}
  },
  "2": {
    "inputs": {
      "lora_name": "lcm-lora-sdv1-5.safetensors",
      "strength_model": 1,
      "strength_clip": 1,
      "model": ["1", 0],
      "clip": ["1", 1]
    },
    "class_type": "LoraLoader",
    "_meta": {"title": "Load LCM LoRA"}
  },
  "3": {
    "inputs": {
      "image": "INPUT_IMAGE",
      "upload": "image"
    },
    "class_type": "LoadImage",
    "_meta": {"title": "Load Image"}
  },
  "4": {
    "inputs": {
      "text": "INPUT_PROMPT",
      "clip": ["2", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Positive Prompt"}
  },
  "5": {
    "inputs": {
      "text": "",
      "clip": ["2", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Negative Prompt"}
  },
  "6": {
    "inputs": {
      "pixels": ["3", 0],
      "vae": ["1", 2]
    },
    "class_type": "VAEEncode",
    "_meta": {"title": "VAE Encode"}
  },
  "7": {
    "inputs": {
      "seed": "INPUT_SEED",
      "steps": 4,
      "cfg": 1.5,
      "sampler_name": "lcm",
      "scheduler": "sgm_uniform",
      "denoise": "INPUT_DENOISE",
      "model": ["2", 0],
      "positive": ["4", 0],
      "negative": ["5", 0],
      "latent_image": ["6", 0]
    },
    "class_type": "KSampler",
    "_meta": {"title": "KSampler LCM"}
  },
  "8": {
    "inputs": {
      "samples": ["7", 0],
      "vae": ["1", 2]
    },
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Decode"}
  },
  "9": {
    "inputs": {
      "filename_prefix": "lcm_variation",
      "images": ["8", 0]
    },
    "class_type": "SaveImage",
    "_meta": {"title": "Save Image"}
  }
}
