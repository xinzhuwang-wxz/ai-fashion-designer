{
  "1": {
    "inputs": {
      "ckpt_name": "v1-5-pruned-emaonly.safetensors"
    },
    "class_type": "CheckpointLoaderSimple",
    "_meta": {"title": "Load Checkpoint"}
  },
  "2": {
    "inputs": {
      "image": "INPUT_IMAGE",
      "upload": "image"
    },
    "class_type": "LoadImage",
    "_meta": {"title": "Load Lineart Image"}
  },
  "3": {
    "inputs": {
      "text": "INPUT_PROMPT",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Positive Prompt"}
  },
  "4": {
    "inputs": {
      "text": "ugly, blurry, low quality, distorted, bad anatomy, watermark, text",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Negative Prompt"}
  },
  "5": {
    "inputs": {
      "control_net_name": "INPUT_CONTROLNET"
    },
    "class_type": "ControlNetLoader",
    "_meta": {"title": "Load ControlNet"}
  },
  "6": {
    "inputs": {
      "strength": 0.8,
      "conditioning": ["3", 0],
      "control_net": ["5", 0],
      "image": ["2", 0]
    },
    "class_type": "ControlNetApply",
    "_meta": {"title": "Apply ControlNet"}
  },
  "7": {
    "inputs": {
      "width": 512,
      "height": 768,
      "batch_size": 1
    },
    "class_type": "EmptyLatentImage",
    "_meta": {"title": "Empty Latent"}
  },
  "8": {
    "inputs": {
      "seed": "INPUT_SEED",
      "steps": 20,
      "cfg": 7.0,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 1.0,
      "model": ["1", 0],
      "positive": ["6", 0],
      "negative": ["4", 0],
      "latent_image": ["7", 0]
    },
    "class_type": "KSampler",
    "_meta": {"title": "KSampler"}
  },
  "9": {
    "inputs": {
      "samples": ["8", 0],
      "vae": ["1", 2]
    },
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Decode"}
  },
  "10": {
    "inputs": {
      "filename_prefix": "fabric_fill",
      "images": ["9", 0]
    },
    "class_type": "SaveImage",
    "_meta": {"title": "Save Image"}
  }
}
