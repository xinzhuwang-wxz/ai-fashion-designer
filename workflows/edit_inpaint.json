{
  "1": {
    "inputs": { "ckpt_name": "v1-5-pruned-emaonly.safetensors" },
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "Load Checkpoint" }
  },
  "2": {
    "inputs": { "image": "INPUT_SOURCE", "upload": "image" },
    "class_type": "LoadImage",
    "_meta": { "title": "Load Source (current render)" }
  },
  "3": {
    "inputs": { "image": "INPUT_MASK", "channel": "red", "upload": "image" },
    "class_type": "LoadImageMask",
    "_meta": { "title": "Load Stroke Mask" }
  },
  "6": {
    "inputs": {
      "grow_mask_by": 6,
      "pixels": ["2", 0],
      "vae": ["1", 2],
      "mask": ["3", 0]
    },
    "class_type": "VAEEncodeForInpaint",
    "_meta": { "title": "VAE Encode (masked) — mask 外像素保留" }
  },
  "7": {
    "inputs": { "text": "INPUT_PROMPT", "clip": ["1", 1] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive" }
  },
  "8": {
    "inputs": {
      "text": "ugly, blurry, low quality, distorted, watermark, text",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative" }
  },
  "9": {
    "inputs": {
      "seed": "INPUT_SEED",
      "steps": 20,
      "cfg": 7.0,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 0.6,
      "model": ["1", 0],
      "positive": ["7", 0],
      "negative": ["8", 0],
      "latent_image": ["6", 0]
    },
    "class_type": "KSampler",
    "_meta": { "title": "KSampler (只采样 mask 区域)" }
  },
  "10": {
    "inputs": { "samples": ["9", 0], "vae": ["1", 2] },
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" }
  },
  "11": {
    "inputs": { "filename_prefix": "edit", "images": ["10", 0] },
    "class_type": "SaveImage",
    "_meta": { "title": "Save" }
  }
}
