{
  "1": {
    "inputs": { "ckpt_name": "sd_xl_base_1.0.safetensors" },
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "Load SDXL Checkpoint" }
  },
  "2": {
    "inputs": { "image": "INPUT_IMAGE", "upload": "image" },
    "class_type": "LoadImage",
    "_meta": { "title": "Load Lineart (白线黑底)" }
  },
  "3": {
    "inputs": { "text": "INPUT_PROMPT", "clip": ["1", 1] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive" }
  },
  "4": {
    "inputs": {
      "text": "ugly, blurry, low quality, distorted, bad anatomy, watermark, text",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative" }
  },
  "5": {
    "inputs": { "control_net_name": "INPUT_CONTROLNET" },
    "class_type": "ControlNetLoader",
    "_meta": { "title": "Load SDXL ControlNet" }
  },
  "6": {
    "inputs": {
      "strength": 0.7,
      "conditioning": ["3", 0],
      "control_net": ["5", 0],
      "image": ["2", 0]
    },
    "class_type": "ControlNetApply",
    "_meta": { "title": "Apply ControlNet" }
  },
  "7": {
    "inputs": { "width": 832, "height": 1216, "batch_size": 1 },
    "class_type": "EmptyLatentImage",
    "_meta": { "title": "Empty Latent (SDXL portrait)" }
  },
  "8": {
    "inputs": {
      "seed": "INPUT_SEED",
      "steps": 25,
      "cfg": 6.5,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["1", 0],
      "positive": ["6", 0],
      "negative": ["4", 0],
      "latent_image": ["7", 0]
    },
    "class_type": "KSampler",
    "_meta": { "title": "KSampler SDXL" }
  },
  "9": {
    "inputs": { "samples": ["8", 0], "vae": ["1", 2] },
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" }
  },
  "10": {
    "inputs": { "filename_prefix": "sdxl", "images": ["9", 0] },
    "class_type": "SaveImage",
    "_meta": { "title": "Save" }
  }
}
