{
  "1": {
    "inputs": { "ckpt_name": "v1-5-pruned-emaonly.safetensors" },
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "Load Checkpoint" }
  },
  "2": {
    "inputs": {
      "lora_name": "lcm-lora-sdv1-5.safetensors",
      "strength_model": 1,
      "strength_clip": 1,
      "model": ["1", 0],
      "clip": ["1", 1]
    },
    "class_type": "LoraLoader",
    "_meta": { "title": "Load LCM LoRA (蒸馏到 1-4 步)" }
  },
  "3": {
    "inputs": { "image": "INPUT_SOURCE", "upload": "image" },
    "class_type": "LoadImage",
    "_meta": { "title": "Load Source (当前成衣)" }
  },
  "4": {
    "inputs": { "image": "INPUT_MASK", "channel": "red", "upload": "image" },
    "class_type": "LoadImageMask",
    "_meta": { "title": "Load Stroke Mask" }
  },
  "5": {
    "inputs": {
      "grow_mask_by": 6,
      "pixels": ["3", 0],
      "vae": ["1", 2],
      "mask": ["4", 0]
    },
    "class_type": "VAEEncodeForInpaint",
    "_meta": { "title": "VAE Encode (masked) — mask 外像素保留" }
  },
  "6": {
    "inputs": { "text": "INPUT_PROMPT", "clip": ["2", 1] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive" }
  },
  "7": {
    "inputs": {
      "text": "ugly, blurry, low quality, distorted, watermark, text",
      "clip": ["2", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative" }
  },
  "8": {
    "inputs": {
      "seed": "INPUT_SEED",
      "steps": 4,
      "cfg": 1.5,
      "sampler_name": "lcm",
      "scheduler": "sgm_uniform",
      "denoise": "INPUT_DENOISE",
      "model": ["2", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0]
    },
    "class_type": "KSampler",
    "_meta": { "title": "KSampler LCM (4 步, 只采样 mask 区)" }
  },
  "9": {
    "inputs": { "samples": ["8", 0], "vae": ["1", 2] },
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" }
  },
  "10": {
    "inputs": { "filename_prefix": "lcm_edit", "images": ["9", 0] },
    "class_type": "SaveImage",
    "_meta": { "title": "Save" }
  }
}
